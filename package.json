{
  "name": "pathforge",
  "version": "0.1.0",
  "private": true,
  "description": "PathForge — Career Intelligence for Everyone",
  "author": "PathForge <hello@pathforge.eu>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter pathforge-mobile start",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@modelcontextprotocol/sdk>ajv": ">=8.18.0",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "flatted@<3.4.0": ">=3.4.0",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "minimatch@<10.2.3": ">=10.2.3",
      "tar@<7.5.10": ">=7.5.10",
      "undici@<6.24.0": ">=6.24.0",
      "express-rate-limit@<8.2.2": ">=8.2.2",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "serialize-javascript@<=7.0.2": ">=7.0.3"
    },
    "auditConfig": {
      "//": "See SECURITY.md §'Ignored CVEs' for per-entry rationale + re-evaluation dates. Every CVE listed below must have a matching row there (P2-8 policy).",
      "ignoreCves": [
        "CVE-2025-69873",
        "CVE-2025-09073"
      ]
    }
  }
}
