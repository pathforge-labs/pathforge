# ─── Resend (Email / Waitlist) ───────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Create an Audience at https://resend.com/audiences
RESEND_AUDIENCE_ID=aud_xxxxxxxxxxxx

# Sender email — must be from a verified domain in Resend
# For development, use "onboarding@resend.dev"
RESEND_FROM_EMAIL=PathForge <hello@pathforge.eu>

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# Create property at https://analytics.google.com → Admin → Data Streams
# Uses Consent Mode v2 — denied by default until user accepts cookies
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google Search Console ───────────────────────────────────────────────────
# Create property at https://search.google.com/search-console
# HTML tag verification code (content value only, not the full meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
# Create a widget at https://dash.cloudflare.com → Application Security → Turnstile
# Mode: Invisible | Domains: your-domain.com, localhost
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAxxxxxxxxx

# ─── Sentry Error Monitoring (Sprint 35) ──────────────────────────────────────
# Create project at https://sentry.io → Projects → Create Project (Next.js)
# DSN is found in Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=

# ── OAuth Social Login (Sprint 39) ──────────────────────────────────────────
# Google: Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
# Microsoft: Register app at https://portal.azure.com → App registrations
NEXT_PUBLIC_MICROSOFT_OAUTH_CLIENT_ID=

# ── Stripe Billing (Sprint 34) ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
